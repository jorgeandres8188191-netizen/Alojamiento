@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

@if (!Model.EstaLogueado)
{
    <div class="ghi-login-wrapper">
        <div class="ghi-login-card">
            <div class="ghi-login-header">
                <span style="font-size:2rem"></span>
                <h2>Gestionamiento de hoteles</h2>
                <p>Sistema de gestión hotelera</p>
            </div>
            <form method="POST">
                <div class="form-group mb-3">
                    <label class="ghi-label">Usuario</label>
                    <input onchange="keyUp(this)"
                           asp-for="@Model.Email"
                           class="form-control ghi-input"
                           placeholder="usuario@email.com" />
                </div>
                <div class="form-group mb-4">
                    <label class="ghi-label">Contraseña</label>
                    <input type="password"
                           onchange="keyUp(this)"
                           asp-for="@Model.Contrasena"
                           class="form-control ghi-input"
                           placeholder="••••••••" />
                </div>
                <div class="d-flex gap-2">
                    <input type="submit"
                           value="Limpiar"
                           asp-page-handler="BtClean"
                           class="btn ghi-btn-secondary flex-fill" />
                    <input type="submit"
                           value="Entrar"
                           asp-page-handler="BtEnter"
                           class="btn ghi-btn-primary flex-fill" />
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div class="ghi-welcome-wrapper">
        <div class="ghi-welcome-card">
            <div class="ghi-welcome-icon">🏨</div>
            <h1>Bienvenido al sistema</h1>
            <p class="ghi-welcome-sub">GestionHoteles — Panel de administración</p>
            <hr class="ghi-divider" />
            <p class="ghi-welcome-desc">
                Esta página tiene como fin registrar, buscar, actualizar y borrar
                información de las entidades relacionadas con gestionamiento de 
                hoteles.

                <h1>Usa el menú superior para navegar entre las secciones.</h1>
            </p>
        </div>
    </div>
}