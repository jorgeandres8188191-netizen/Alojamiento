@page
@model asp_presentacion.Pages.Ventanas.HabitacionesModel
@{
    ViewData["Titulo"] = "";
}
<center>
    <div>
        <form method="POST"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Información de habitaciones</h3>
            </div>
            <div align="left"
                 class="bt_panel_buttons">
                <input type="submit"
                       value="Refrescar"
                       asp-page-handler="BtRefrescar"
                       class="btn btn-secondary"
                       disabled="@(Model.Accion != lib_dominio.Nucleo.Enumerables.Ventanas.Listas)" />
                <input type="submit"
                       value="Nuevo"
                       asp-page-handler="BtNuevo"
                       class="btn btn-secondary"
                       disabled="@(Model.Accion != lib_dominio.Nucleo.Enumerables.Ventanas.Listas)" />
                <input type="submit"
                       value="Guardar"
                       asp-page-handler="BtGuardar"
                       class="btn btn-secondary"
                       disabled="@(Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Listas)" />
                <input type="submit"
                       value="Cancelar"
                       asp-page-handler="BtCancelar"
                       class="btn btn-secondary"
                       disabled="@(Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Listas)" />
                <a asp-page="/Index" class="btn ghi-btn-home ms-2">Regresar al Inicio</a>
            </div>

            @if (Model.Accion != lib_dominio.Nucleo.Enumerables.Ventanas.Listas ||
                        Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Borrar)
            {
                <input type="hidden"
                       asp-for="@Model.Actual!.Id" />
                <input type="hidden"
                       asp-for="@Model.Actual!.Numero" />
                <input type="hidden"
                       asp-for="@Model.Actual!.Piso" />
                <input type="hidden"
                       asp-for="@Model.Actual!.PrecioDia" />
                <input type="hidden"
                       asp-for="@Model.Actual!.Capacidad" />
                <input type="hidden"
                       asp-for="@Model.Actual!.IdHotel" />
                <input type="hidden"
                       asp-for="@Model.Actual!.IdTipoHabitacion" />
                <input type="hidden"
                       asp-for="@Model.Actual!.IdEstadoHabitacion" />
            }
            @if (Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Borrar)
            {
                <input type="hidden"
                       asp-for="@Model.Actual!.Id" />
                <input type="hidden"
                       asp-for="@Model.Actual!.Numero" />
                <input type="hidden"
                       asp-for="@Model.Actual!.Piso" />
                <input type="hidden"
                       asp-for="@Model.Actual!.PrecioDia" />
                <input type="hidden"
                       asp-for="@Model.Actual!.Capacidad" />
                <input type="hidden"
                       asp-for="@Model.Actual!.IdHotel" />
                <input type="hidden"
                       asp-for="@Model.Actual!.IdTipoHabitacion" />
                <input type="hidden"
                       asp-for="@Model.Actual!.IdEstadoHabitacion" />
            }

            @if (Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Editar)
            {
                <div class="containers_vn panel panel-default">
                    <h3>Habitaciones registradas</h3>

                    <div>
                        <div class="form-group">
                            <label class="col-lg-4 control-label">
                                Número
                            </label>
                            <div class="col-lg-6">
                                <input id="nmNumero"
                                       class="cts_forms form-control"
                                       asp-for="@Model.Actual!.Numero" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-4 control-label">
                                Piso
                            </label>
                            <div class="col-lg-6">
                                <input id="nmPiso"
                                       class="cts_forms form-control"
                                       asp-for="@Model.Actual!.Piso" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-4 control-label">
                                Precio por día
                            </label>
                            <div class="col-lg-6">
                                <input id="nmPrecioDia"
                                       class="cts_forms form-control"
                                       asp-for="@Model.Actual!.PrecioDia" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-4 control-label">
                                Capacidad
                            </label>
                            <div class="col-lg-6">
                                <input id="nmCapacidad"
                                       class="cts_forms form-control"
                                       asp-for="@Model.Actual!.Capacidad" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-4 control-label">
                                ID del hotel
                            </label>
                            <div class="col-lg-6">
                                <input id="nmIdHotel"
                                       class="cts_forms form-control"
                                       asp-for="@Model.Actual!.IdHotel" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-4 control-label">
                                ID del Tipo de habitación
                            </label>
                            <div class="col-lg-6">
                                <input id="nmIdTipoHabitacion"
                                       class="cts_forms form-control"
                                       asp-for="@Model.Actual!.IdTipoHabitacion" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-lg-4 control-label">
                                ID del estado de habitación
                            </label>
                            <div class="col-lg-6">
                                <input id="nmIdEstadoHabitacion"
                                       class="cts_forms form-control"
                                       asp-for="@Model.Actual!.IdEstadoHabitacion" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (ViewData.ContainsKey("Mensaje"))
            {
                <input type="hidden"
                       asp-for="@Model.Accion" />
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
                ;
            }

            @if (Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Borrar)
            {
                <div class='popup'>
                    <div class='pp_del_inner'>
                        <div style='width:95%'>
                            <h2 align="left">
                                Mensaje
                            </h2>

                            <h4 align="left">
                                ¿Desea borrar esta habitación?
                            </h4>
                            <h6 align="left">
                                @Model.Actual!.Numero,
                                @Model.Actual!.IdHotel
                            </h6>
                            <br />
                            <br />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCancelar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Listas ||
                        Model.Accion == lib_dominio.Nucleo.Enumerables.Ventanas.Borrar)
            {
                /*<input id="flIdTelefonoAcompañante"
                       class="cts_forms form-control"
                       asp-for="@Model.Filtro!.IdTelefonoAcompañante"
                       placeholder="IdTelefonoAcompañante" />
                <br />*/

                <div class="containers_vn panel panel-default">


                    <table class="tb_data table table-striped table-bordered table
    hover">
                        <tr>
                            <th>
                                Número
                            </th>
                            <th>
                                Piso
                            </th>
                            <th>
                                Precio por día
                            </th>
                            <th>
                                Capacidad
                            </th>
                            <th>
                                ID del hotel
                            </th>
                            <th class="cl_hidden">
                                IdTipoHabitacion
                            </th>
                            <th class="cl_hidden">
                                IdEstadoHabitacion
                            </th>
                            <th class="cl_actions">
                                Accion
                            </th>
                        </tr>
                        @if (Model != null && Model.Lista != null)
                        {
                            @foreach (var elemento in Model.Lista)
                            {
                                <tr>
                                    <td>
                                        @elemento.Numero
                                    </td>
                                    <td>
                                        @elemento.Piso
                                    </td>
                                    <th>
                                        @elemento.PrecioDia
                                    </th>
                                    <th>
                                        @elemento.Capacidad
                                    </th>
                                    <th>
                                        @elemento.IdHotel
                                    </th>
                                    <td class="cl_hidden">
                                        @elemento.IdTipoHabitacion
                                    </td>
                                    <td class="cl_hidden">
                                        @elemento.IdEstadoHabitacion
                                    </td>                                   
                                    <td>
                                        <input type="submit"
                                               value="Modicar"
                                               asp-page-handler="BtModificar"
                                               class="btn btn-secondary"
                                               asp-route-data="@elemento.Id" />
                                        <input type="submit"
                                               value="Borrar"
                                               asp-page-handler="BtBorrarVal"
                                               class="btn btn-secondary"
                                               asp-route-data="@elemento.Id" />
                                    </td>
                                </tr>
                            }
                        }
                    </table>
                </div>
            }
        </form>
    </div>
</center>